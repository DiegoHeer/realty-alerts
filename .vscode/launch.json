{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Scraper",
            "type": "debugpy",
            "request": "launch",
            "module": "scraper",
            "cwd": "${workspaceFolder}/services/scraper",
            "python": "${workspaceFolder}/services/scraper/.venv/bin/python",
            "envFile": "${workspaceFolder}/services/scraper/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/services/scraper/src"
            },
            "justMyCode": false
        },
        {
            "name": "Python: API (Django)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/services/api/manage.py",
            "args": ["runserver", "0.0.0.0:8000", "--noreload"],
            "cwd": "${workspaceFolder}/services/api",
            "python": "${workspaceFolder}/services/api/.venv/bin/python",
            "envFile": "${workspaceFolder}/services/api/.env",
            "django": true,
            "justMyCode": false
        },
        {
            "name": "Pytest: Scraper (current file)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}", "-v"],
            "cwd": "${workspaceFolder}/services/scraper",
            "python": "${workspaceFolder}/services/scraper/.venv/bin/python",
            "envFile": "${workspaceFolder}/services/scraper/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/services/scraper/src"
            },
            "justMyCode": false
        },
        {
            "name": "Pytest: API (current file)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}", "-v"],
            "cwd": "${workspaceFolder}/services/api",
            "python": "${workspaceFolder}/services/api/.venv/bin/python",
            "envFile": "${workspaceFolder}/services/api/.env",
            "justMyCode": false
        },
        {
            "name": "Web: Next.js (dev)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/apps/web"
        },
        {
            "name": "Vitest: Web (current file)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["vitest", "run", "${file}"],
            "cwd": "${workspaceFolder}/apps/web",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Mobile: Expo (start)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm start",
            "cwd": "${workspaceFolder}/apps/mobile"
        },
        {
            "name": "Jest: Mobile (current file)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["jest", "${file}", "--runInBand"],
            "cwd": "${workspaceFolder}/apps/mobile",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        }
    ]
}
