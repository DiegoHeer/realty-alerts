{
  "shadow": {
    "color": {
      "$value": "rgba(15, 30, 63, 0.12)",
      "$type": "color",
      "$description": "Navy-tinted shadow base color"
    },
    "color-strong": {
      "$value": "rgba(15, 30, 63, 0.24)",
      "$type": "color",
      "$description": "Stronger shadow for elevated elements"
    },
    "distance": {
      "x": {
        "$value": "0",
        "$type": "dimension",
        "$description": "Shadow horizontal offset"
      },
      "y": {
        "$value": "0",
        "$type": "dimension",
        "$description": "Shadow vertical offset"
      }
    },
    "outer": {
      "soft": {
        "xs": {
          "$value": [
            {
              "offsetX": "{shadow.distance.x}",
              "offsetY": "1",
              "blur": "2",
              "spread": "0",
              "color": "{shadow.color}",
              "inset": false
            }
          ],
          "$type": "shadow",
          "$description": "Subtle lift — cards on surface"
        },
        "sm": {
          "$value": [
            {
              "offsetX": "{shadow.distance.x}",
              "offsetY": "2",
              "blur": "4",
              "spread": "0",
              "color": "{shadow.color}",
              "inset": false
            }
          ],
          "$type": "shadow",
          "$description": "Default card shadow"
        },
        "md": {
          "$value": [
            {
              "offsetX": "{shadow.distance.x}",
              "offsetY": "4",
              "blur": "8",
              "spread": "-1",
              "color": "{shadow.color}",
              "inset": false
            }
          ],
          "$type": "shadow",
          "$description": "Dropdown, popover"
        },
        "lg": {
          "$value": [
            {
              "offsetX": "{shadow.distance.x}",
              "offsetY": "8",
              "blur": "16",
              "spread": "-2",
              "color": "{shadow.color}",
              "inset": false
            }
          ],
          "$type": "shadow",
          "$description": "Modal, bottom sheet"
        },
        "xl": {
          "$value": [
            {
              "offsetX": "{shadow.distance.x}",
              "offsetY": "16",
              "blur": "32",
              "spread": "-4",
              "color": "{shadow.color-strong}",
              "inset": false
            }
          ],
          "$type": "shadow",
          "$description": "Floating action, toast"
        }
      },
      "hard": {
        "sm": {
          "$value": [
            {
              "offsetX": "{shadow.distance.x}",
              "offsetY": "2",
              "blur": "0",
              "spread": "0",
              "color": "{shadow.color}",
              "inset": false
            }
          ],
          "$type": "shadow",
          "$description": "Sharp edge — pressed state, retro"
        },
        "md": {
          "$value": [
            {
              "offsetX": "{shadow.distance.x}",
              "offsetY": "4",
              "blur": "0",
              "spread": "0",
              "color": "{shadow.color}",
              "inset": false
            }
          ],
          "$type": "shadow",
          "$description": "Medium hard shadow — graphic emphasis"
        }
      }
    },
    "inner": {
      "soft": {
        "sm": {
          "$value": [
            {
              "offsetX": "{shadow.distance.x}",
              "offsetY": "1",
              "blur": "2",
              "spread": "0",
              "color": "{shadow.color}",
              "inset": true
            }
          ],
          "$type": "shadow",
          "$description": "Inset — input fields, wells"
        },
        "md": {
          "$value": [
            {
              "offsetX": "{shadow.distance.x}",
              "offsetY": "2",
              "blur": "4",
              "spread": "0",
              "color": "{shadow.color}",
              "inset": true
            }
          ],
          "$type": "shadow",
          "$description": "Medium inset shadow — deeper wells"
        }
      }
    }
  }
}
