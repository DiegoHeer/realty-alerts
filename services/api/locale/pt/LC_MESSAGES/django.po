#: scraping/templates/account/email/base_email.html:29
#: scraping/templates/account/email/base_message_branded.txt:4
msgid "A zero-data company. Your searches stay yours."
msgstr "Uma empresa sem recolha de dados. As suas pesquisas são só suas."

#: scraping/templates/account/email/base_email.html:31
msgid "Open Huismus"
msgstr "Abrir o Huismus"

#: scraping/templates/account/email/base_email.html:33
msgid "Privacy"
msgstr "Privacidade"

#: scraping/templates/account/email/base_email.html:36
msgid "You're receiving this email because you have a Huismus account."
msgstr "Está a receber este e-mail porque tem uma conta Huismus."

#: scraping/templates/account/email/base_email.html:36
msgid "Netherlands"
msgstr "Países Baixos"

#: scraping/templates/account/email/email_confirmation_message.html:3
msgid "Enter your code to confirm this email address — expires in 15 minutes."
msgstr "Introduza o seu código para confirmar este e-mail — expira em 15 minutos."

#: scraping/templates/account/email/email_confirmation_message.html:5
#: scraping/templates/account/email/email_confirmation_message.txt:3
#: scraping/templates/account/email/email_confirmation_subject.txt:1
msgid "Confirm your email address"
msgstr "Confirme o seu e-mail"

#: scraping/templates/account/email/email_confirmation_message.html:6
#: scraping/templates/account/email/email_confirmation_message.txt:5
msgid "Enter this code to confirm this email address for your Huismus account."
msgstr "Introduza este código para confirmar este e-mail na sua conta Huismus."

#: scraping/templates/account/email/email_confirmation_message.html:7
msgid "Your confirmation code"
msgstr "O seu código de confirmação"

#: scraping/templates/account/email/email_confirmation_message.html:8
#: scraping/templates/account/email/email_confirmation_message.txt:9
#: scraping/templates/account/email/email_confirmation_signup_message.html:8
#: scraping/templates/account/email/email_confirmation_signup_message.txt:9
#: scraping/templates/account/email/password_reset_code_message.html:8
#: scraping/templates/account/email/password_reset_code_message.txt:9
msgid "This code expires in 15 minutes."
msgstr "Este código expira em 15 minutos."

#: scraping/templates/account/email/email_confirmation_message.html:9
#: scraping/templates/account/email/email_confirmation_message.txt:11
msgid "Didn't request this? You can safely ignore this email."
msgstr "Não solicitou isto? Pode ignorar este e-mail em segurança."

#: scraping/templates/account/email/email_confirmation_signup_message.html:3
msgid ""
"Enter your code to finish setting up your account — expires in 15 minutes."
msgstr "Introduza o seu código para concluir a criação da conta — expira em 15 minutos."

#: scraping/templates/account/email/email_confirmation_signup_message.html:5
#: scraping/templates/account/email/email_confirmation_signup_message.txt:3
msgid "Verify your email"
msgstr "Verifique o seu e-mail"

#: scraping/templates/account/email/email_confirmation_signup_message.html:6
#: scraping/templates/account/email/email_confirmation_signup_message.txt:5
msgid "Welcome to Huismus! Enter this code to finish creating your account."
msgstr "Bem-vindo ao Huismus! Introduza este código para concluir a criação da sua conta."

#: scraping/templates/account/email/email_confirmation_signup_message.html:7
msgid "Your verification code"
msgstr "O seu código de verificação"

#: scraping/templates/account/email/email_confirmation_signup_message.html:9
#: scraping/templates/account/email/email_confirmation_signup_message.txt:11
msgid ""
"Didn't create a Huismus account? You can safely ignore this email — nothing "
"will happen."
msgstr "Não criou uma conta Huismus? Pode ignorar este e-mail em segurança — nada acontecerá."

#: scraping/templates/account/email/email_confirmation_signup_subject.txt:1
msgid "Verify your email address"
msgstr "Verifique o seu e-mail"

#: scraping/templates/account/email/password_reset_code_message.html:3
msgid "Use your code to choose a new password — expires in 15 minutes."
msgstr "Utilize o seu código para escolher uma nova palavra-passe — expira em 15 minutos."

#: scraping/templates/account/email/password_reset_code_message.html:5
#: scraping/templates/account/email/password_reset_code_message.txt:3
#: scraping/templates/account/email/password_reset_code_subject.txt:1
msgid "Reset your password"
msgstr "Redefinir a palavra-passe"

#: scraping/templates/account/email/password_reset_code_message.html:6
#: scraping/templates/account/email/password_reset_code_message.txt:5
msgid ""
"We received a request to reset your Huismus password. Enter this code to "
"choose a new one."
msgstr "Recebemos um pedido para redefinir a sua palavra-passe do Huismus. Introduza este código para escolher uma nova."

#: scraping/templates/account/email/password_reset_code_message.html:7
msgid "Your reset code"
msgstr "O seu código de redefinição"

#: scraping/templates/account/email/password_reset_code_message.html:9
#: scraping/templates/account/email/password_reset_code_message.txt:11
msgid ""
"Didn't request this? You can safely ignore this email — your password won't "
"change."
msgstr "Não solicitou isto? Pode ignorar este e-mail em segurança — a sua palavra-passe não será alterada."
